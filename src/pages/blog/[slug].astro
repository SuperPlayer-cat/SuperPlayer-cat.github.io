---
import type { CollectionEntry } from "astro:content"
import BaseLayout from "../../layouts/BaseLayout.astro"
import GiscusComment from "../../components/GiscusComment.vue"
import { getCollection } from "astro:content"
import blogConfig from "../../blog.config"

export async function getStaticPaths() {
  const posts = await getCollection("posts")
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }))
}

type Props = {
  post: CollectionEntry<"posts">
}

const { post } = Astro.props as Props
const { Content } = await post.render()
const giscus = blogConfig.giscus
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  active="blog"
>
  <article class="post-article">
    <div class="container-main">
      <header class="post-header">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time datetime={post.data.publishedAt.toISOString()}>
            {new Date(post.data.publishedAt).toLocaleDateString("zh-CN", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map((tag: string) => (
                <a href={`/tags/${tag}`} class="post-tag">{tag}</a>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <GiscusComment
        client:load
        repo={giscus.repo}
        repoId={giscus.repoId}
        category={giscus.category}
        categoryId={giscus.categoryId}
        mapping={giscus.mapping}
      />

      <footer class="post-footer">
        <a href="/blog" class="back-link">← 返回博客</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-article {
    padding: 60px 0;
  }

  .post-header {
    margin-bottom: 40px;
    text-align: center;
  }

  .post-title {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--text-main);
    line-height: 1.3;
    margin-bottom: 16px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .post-tag {
    font-size: 0.75rem;
    padding: 3px 10px;
    background: var(--bg-active);
    color: var(--primary);
    border-radius: 4px;
    border: 1px solid var(--border-light);
  }

  .post-tag:hover {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
  }

  .post-content {
    max-width: 760px;
    margin: 0 auto;
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-main);
  }

  .post-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 48px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-light);
  }

  .post-content :global(h3) {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 36px 0 12px;
  }

  .post-content :global(p) {
    margin-bottom: 20px;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 2px 6px;
    background: var(--bg-panel);
    border-radius: 4px;
    border: 1px solid var(--border-light);
  }

  .post-content :global(pre) {
    border-radius: 8px;
    margin: 24px 0;
    overflow-x: auto;
  }

  .post-content :global(pre code) {
    padding: 0;
    background: transparent;
    border: none;
    font-size: 0.9rem;
  }

  .post-content :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--primary);
    padding-left: 16px;
    margin: 20px 0;
    color: var(--text-muted);
  }

  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 20px;
    padding-left: 24px;
  }

  .post-content :global(ul) {
    list-style: disc;
  }

  .post-content :global(ol) {
    list-style: decimal;
  }

  .post-content :global(li) {
    margin-bottom: 6px;
  }

  .post-content :global(img) {
    border-radius: 8px;
    margin: 20px auto;
    max-width: 100%;
  }

  .post-footer {
    max-width: 760px;
    margin: 60px auto 0;
    padding-top: 32px;
    border-top: 1px solid var(--border-light);
  }

  .back-link {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.8rem;
    }
  }
</style>
