---
import BaseLayout from "../../layouts/BaseLayout.astro"
import BlogCard from "../../components/BlogCard.vue"
import ScrollReveal from "../../components/ScrollReveal.vue"
import TagFilter from "../../components/TagFilter.vue"
import { getCollection } from "astro:content"

const posts = await getCollection("posts")
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
)

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))].sort() as string[]
---

<BaseLayout title="博客" active="blog">
  <section class="section-padding">
    <div class="container-main">
      <h2 class="section-title">博客</h2>

      {
        allTags.length > 0 && (
          <TagFilter client:load tags={allTags} modelValue="" />
        )
      }

      {
        sortedPosts.length === 0 ? (
          <p class="empty-text">暂无文章</p>
        ) : (
          <div class="posts-grid">
            {sortedPosts.map((post, i) => (
              <div style={`--reveal-delay: ${i * 80}ms`}>
                <ScrollReveal client:load>
                  <BlogCard
                    client:load
                    title={post.data.title}
                    description={post.data.description}
                    date={new Date(post.data.publishedAt).toLocaleDateString("zh-CN")}
                    tags={post.data.tags}
                    href={`/blog/${post.id.replace(/\.md$/, "")}`}
                  />
                </ScrollReveal>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
    gap: 24px;
  }

  .empty-text {
    text-align: center;
    color: var(--text-muted);
    font-size: 1.05rem;
    padding: 32px 0;
  }
</style>
