---
import BaseLayout from "../layouts/BaseLayout.astro"
import HeroSection from "../components/HeroSection.vue"
import BlogCard from "../components/BlogCard.vue"
import ScrollReveal from "../components/ScrollReveal.vue"
import { getCollection } from "astro:content"

const posts = await getCollection("posts")
const sortedPosts = posts
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 6)
---

<BaseLayout title="首页" active="home">
  <HeroSection client:load />

  <section id="posts" class="section-padding">
    <div class="container-main">
      <h2 class="section-title">最新文章</h2>

      {
        sortedPosts.length === 0 ? (
          <p class="empty-text">暂无文章，敬请期待...</p>
        ) : (
          <div class="posts-grid">
            {sortedPosts.map((post, i) => (
              <div style={`--reveal-delay: ${i * 80}ms`}>
                <ScrollReveal client:load>
                  <BlogCard
                    client:load
                    title={post.data.title}
                    description={post.data.description}
                    date={new Date(post.data.publishedAt).toLocaleDateString("zh-CN")}
                    tags={post.data.tags}
                    href={`/blog/${post.id.replace(/\.md$/, "")}`}
                  />
                </ScrollReveal>
              </div>
            ))}
          </div>
        )
      }

      {
        sortedPosts.length > 0 && (
          <div class="view-all-wrap">
            <a href="/blog" class="view-all-link">查看全部文章 →</a>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
    gap: 24px;
  }

  .empty-text {
    text-align: center;
    color: var(--text-muted);
    font-size: 1.05rem;
    padding: 32px 0;
  }

  .view-all-wrap {
    text-align: center;
    margin-top: 32px;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 10px 24px;
    border: 1px solid var(--border-light);
    border-radius: 20px;
    background: var(--bg-toolbar);
    transition: transform 0.18s, border-color 0.18s, background-color 0.18s;
  }

  .view-all-link:hover {
    transform: translateY(-1px);
    border-color: var(--primary);
    background: var(--bg-active);
  }
</style>
