---
import "../styles/global.css"
import NavBar from "../components/NavBar.vue"
import Footer from "../components/Footer.vue"

interface Props {
  title: string
  description?: string
  active?: string
}

const { title, description, active } = Astro.props
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || `${title} - 小鱼干个人技术博客`} />
    <title>{title} | 小鱼干</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>
      (function() {
        const t = localStorage.getItem('theme')
        document.documentElement.setAttribute('data-theme', t === 'dark' ? 'dark' : 'light')
      })()
    </script>
  </head>
  <body>
    <NavBar active={active} client:load />
    <main>
      <slot />
    </main>
    <Footer client:load />
  </body>
</html>

<style is:global>
  /* NavBar is client:load so its styles are in the Vue SFC */
</style>
